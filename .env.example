# Gaggiuino machine URL (use IP address - mDNS doesn't work in Docker)
GAGGIUINO_URL=http://192.168.1.100

# Polling interval in seconds
POLL_INTERVAL=30

# Full sync interval (profiles + settings) in seconds
FULL_SYNC_INTERVAL=600

# Database path (should be on a mounted volume in Docker)
DB_PATH=/data/gaggiuino_shadow.db

# Log level
LOG_LEVEL=INFO

# Auto-prune status history older than N days
STATUS_HISTORY_MAX_AGE_DAYS=30

# Auto-prune health history older than N days
HEALTH_HISTORY_MAX_AGE_DAYS=90
